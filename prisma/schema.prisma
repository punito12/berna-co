// Berna&co data model. See docs/ROADMAP "Modelo de datos".
// SQLite has no native enums, so enum-like fields are stored as String and
// validated in application code (lib/). Allowed values are documented inline.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Product {
  id          String  @id @default(cuid())
  name        String
  description String // short description, shown on the catalog cards
  longDescription String @default("") // full description, shown on the detail page
  slug        String  @unique
  weightGrams Int
  category    String // CARNE | POLLO | CERDO | VEGANO
  price       Int // default/fallback price (in pesos). Admin loads it. Placeholder 0.
  imageUrl    String // cover photo, shown on the catalog cards

  // JSON map of price per empanado, e.g. {"TRADITIONAL":8500,"KETO":9000}.
  // Falls back to `price` when a breadcrumb has no specific entry.
  prices String @default("{}")
  available   Boolean @default(true)
  isNew       Boolean @default(false)
  stock       Int     @default(0) // legacy/fallback total; per-empanado lives in `stocks`

  // JSON map of stock per empanado, e.g. {"TRADITIONAL":10,"KETO":5}.
  // When set, it overrides `stock`. Each variant is sold/decremented on its own.
  stocks String @default("{}")

  // JSON array of photo paths for the product detail gallery, e.g.
  // ["/images/productos/peceto-pastura.jpg","/images/productos/peceto-pastura-2.jpg"]
  images String @default("[]")

  // JSON array of allowed breadcrumb types, e.g. ["TRADITIONAL","INTEGRAL","KETO"]
  availableBreadcrumbs String

  // JSON array of breadcrumb types temporarily turned OFF by the admin, e.g.
  // ["KETO"]. They keep their price/stock/photos but aren't sold until re-enabled.
  disabledBreadcrumbs String @default("[]")

  // Current cost per kg (pesos), loaded by the admin. Used for margin/profit.
  costPerKg Int @default(0)

  // Per-empanado cost (pesos per kg), JSON like `prices`, e.g.
  // {"TRADITIONAL":16048,"KETO":18048}. Source of truth for Costos y Precios.
  costs String @default("{}")

  // --- Automatic per-product promotions (web store) ---
  // Legacy product-wide promo (kept for back-compat / fallback).
  promoPercent Int @default(0)
  promoType String @default("")
  // Per-empanado promos (override the product-wide ones when present):
  // promoPercents JSON {empanado: percent}, e.g. {"KETO":20}
  // promoTypes   JSON {empanado: "2x1"|"3x2"}, e.g. {"KETO":"2x1"}
  promoPercents String @default("{}")
  promoTypes    String @default("{}")

  orderItems     OrderItem[]
  saleItems      SaleItem[]
  stockMovements StockMovement[]
  costSheets     CostSheet[]
  costHistory    CostHistory[]
  priceHistory   PriceHistory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// A single change to a product's per-empanado stock, with its cause. Quantity
// is signed: positive adds stock (producción, ajuste +), negative removes it
// (venta, merma, ajuste −). The reference links to the sale/order/purchase that
// originated it (when applicable), so the history is auditable.
model StockMovement {
  id   String   @id @default(cuid())
  date DateTime @default(now())

  productId      String
  product        Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  breadcrumbType String // TRADITIONAL | INTEGRAL | KETO

  quantity Int // signed units (+ adds, − removes)
  type     String // PRODUCTION | SALE | ADJUSTMENT | WASTE | PURCHASE

  // What originated the movement (for the audit trail + linking back).
  referenceType String? // ORDER | MANUAL_SALE | PURCHASE | MANUAL
  referenceId   String?

  notes String?

  createdAt DateTime @default(now())

  @@index([productId])
  @@index([date])
  @@index([type])
}

model Order {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  status String @default("PENDING") // PENDING | CONFIRMED | READY | DELIVERED | CANCELLED

  customerName  String
  customerPhone String
  customerEmail String? // optional

  deliveryType String // DELIVERY | PICKUP
  address      String? // only for DELIVERY
  lat          Float? // geocoded coordinates of the address (DELIVERY)
  lng          Float?

  scheduledDate DateTime
  scheduledSlot String // e.g. "10:00–12:00"

  paymentMethod String // MERCADOPAGO | CASH
  shippingCost  Int     @default(0) // delivery fee included in `total`
  discountCode  String? // code applied (if any)
  discountAmount Int    @default(0) // total discount in pesos (promos + code)
  total         Int
  mpPaymentId   String? // null when paying cash
  notes         String?

  // Web orders are linked to a Customer (auto-created/reused by name+phone).
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  // Cuenta corriente: PAID = saldado, PARTIAL = pago parcial, PENDING = a deber.
  // Web orders are PAID (MP webhook / cash on confirm); CxC is mainly for sales.
  paymentStatus String    @default("PAID") // PAID | PARTIAL | PENDING
  dueDate       DateTime? // vencimiento (cuenta corriente)

  items    OrderItem[]
  payments Payment[]
}

model OrderItem {
  id          String @id @default(cuid())
  orderId     String
  productId   String
  quantity    Int
  priceAtTime Int

  breadcrumbType String // TRADITIONAL | INTEGRAL | KETO

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
}

model DeliverySlot {
  id        String  @id @default(cuid())
  label     String // e.g. "10:00–12:00"
  available Boolean @default(true)
}

model AvailableDeliveryDay {
  id        String  @id @default(cuid())
  dayOfWeek Int     @unique // 0=Sun ... 6=Sat
  available Boolean @default(true)
}

// Newsletter subscribers captured from the footer form.
model Subscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

// A delivery zone is a polygon on the map plus the weekdays we deliver inside
// it. Coverage is decided by point-in-polygon on the customer's coordinates.
model Zone {
  id   String @id @default(cuid())
  name String // e.g. "San Isidro", "Zona Norte"
  // The coverage area as a GeoJSON geometry (Polygon), stored as a JSON string.
  // null/empty until the admin draws it on the map.
  polygon String?
  // JSON array of weekday numbers we deliver here, e.g. [1,3,5] (0=Sun..6=Sat).
  daysOfWeek String @default("[]")
  active    Boolean @default(true)

  // Delivery pricing for this zone (in pesos).
  shippingCost Int @default(0) // flat delivery fee
  // Free delivery when the products subtotal reaches this amount; 0 = never free.
  freeShippingFrom Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ---- Admin management (clients, manual sales, profitability) ----

// A wholesale/retail customer for manual sales. type drives the default
// discount, which can still be overridden per sale.
// A barrio (closed neighborhood). Created by the admin, then assigned to
// customers from a dropdown.
model Barrio {
  id        String     @id @default(cuid())
  name      String     @unique
  customers Customer[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Customer {
  id              String  @id @default(cuid())
  name            String
  type            String  @default("MINORISTA") // MINORISTA | MAYORISTA | KIOSCO
  defaultDiscount Int     @default(0) // percent (0..100)
  phone           String?
  email           String?
  notes           String?
  lot             String? // lote within the barrio
  // Source: WEB (auto-created from a web order) or MANUAL (loaded by the admin).
  source          String  @default("MANUAL")

  barrioId String?
  barrio   Barrio? @relation(fields: [barrioId], references: [id], onDelete: SetNull)

  sales  ManualSale[]
  orders Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// A sale entered by hand (not from the web): WhatsApp, wholesale, kiosk, etc.
// Totals are stored in pesos and recomputed server-side from the items.
model ManualSale {
  id         String   @id @default(cuid())
  soldAt     DateTime // sale date (admin chooses it)
  channel    String // WEB | WHATSAPP | MAYORISTA | KIOSCO
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  // Free-text customer name when not picking one from the list.
  customerName String?
  // Neighborhood snapshot (from the chosen customer) for billing breakdown.
  neighborhood String?

  discountPct Int @default(0) // discount applied to this sale (percent)
  // Stored money fields (pesos): gross = sum of item subtotals (no discount),
  // discountAmount = gross - net, net = what was charged.
  gross          Int
  discountAmount Int
  net            Int

  notes String?

  // Cuenta corriente: PAID por defecto; los mayoristas nacen PENDING a 30 días.
  paymentStatus String    @default("PAID") // PAID | PARTIAL | PENDING
  dueDate       DateTime? // vencimiento (cuenta corriente)

  // Estado logístico de la venta, separado del pago. Al cancelar se reintegra
  // el stock descontado al cargarla.
  deliveryStatus String @default("PENDING") // PENDING | DELIVERED | CANCELLED

  items    SaleItem[]
  payments Payment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// A payment received against a sale or order (cuenta corriente). Each payment
// creates a CashMovement of type INCOME. A sale/order may have many payments
// (partial). paymentStatus on the sale is recomputed from the sum of payments.
model Payment {
  id     String   @id @default(cuid())
  date   DateTime @default(now())
  amount Int // pesos, positive
  method String // EFECTIVO | MERCADO_PAGO | TRANSFERENCIA
  notes  String?

  // Linked to at most one of these.
  orderId String?
  order   Order?  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  saleId  String?
  sale    ManualSale? @relation(fields: [saleId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([orderId])
  @@index([saleId])
}

// One product line within a manual sale. Quantities are in units.
model SaleItem {
  id        String @id @default(cuid())
  saleId    String
  sale      ManualSale @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  // Snapshot of the product name (so it survives product deletion / free items).
  productName String
  // Chosen empanado (breadcrumb) — used to discount the right stock bucket.
  breadcrumbType String?

  quantity     Int // units sold
  unitPrice    Int // price per unit at sale time (pesos)
  lineSubtotal Int // quantity * unitPrice, before the sale discount (pesos)
}

// Cash box (Caja) movement: an income or expense, manual or auto-generated from
// a web order / manual sale. MP incomes carry the real accrual date so the box
// can separate money available today from money pending release.
model CashMovement {
  id   String   @id @default(cuid())
  date DateTime // when the movement happened (income earned / expense paid)

  type   String // INCOME | EXPENSE
  amount Int // pesos, always positive; `type` gives the sign

  description String
  category    String // expense categories or income label (see lib/cash.ts)

  // INCOME source channel. EXPENSE rows leave this empty.
  source String @default("") // EFECTIVO | MERCADO_PAGO | TRANSFERENCIA

  // AVAILABLE = counted in today's balance. PENDING = money not released yet
  // (MP), counted in "a acreditar" until `accrualDate` passes.
  status      String    @default("AVAILABLE")
  accrualDate DateTime? // real money_release_date for MP; null = immediate

  // Links back to the origin so movements are idempotent (one per payment/order).
  paymentId  String? @unique // MP payment id
  orderId    String? // web order that generated this movement
  saleId     String? // manual sale that generated this movement
  purchaseId String? // supplier purchase that generated this expense

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
  @@index([status, accrualDate])
}

// A supplier (proveedor) the business buys from.
model Supplier {
  id              String  @id @default(cuid())
  name            String
  type            String  @default("OTROS") // CARNE | HUEVOS | PACKAGING | SERVICIOS | OTROS
  contact         String? // phone / email / contact name
  notes           String?
  defaultDueDays  Int     @default(30) // credit term used by default for purchases

  purchases Purchase[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// A purchase (compra / orden de compra) made to a supplier. Totals in pesos.
model Purchase {
  id         String   @id @default(cuid())
  date       DateTime // purchase date (admin chooses it)
  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  // gross = Σ item subtotals; discountAmount; total = gross − discountAmount.
  gross          Int
  discountAmount Int @default(0)
  total          Int

  // Cuenta por pagar: PAID por defecto si se carga ya pagada; PENDING si queda
  // a deber (con vencimiento). Recalculado desde la suma de pagos.
  paymentStatus String    @default("PENDING") // PAID | PARTIAL | PENDING
  dueDate       DateTime?

  notes String?

  items    PurchaseItem[]
  payments SupplierPayment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([supplierId])
}

// One line within a purchase. Quantities are free-form (kg, units, etc.).
model PurchaseItem {
  id         String   @id @default(cuid())
  purchaseId String
  purchase   Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)

  description String
  quantity    Float // amount bought
  unit        String  @default("unidades") // kg | unidades | cajas | ...
  unitPrice   Int // pesos per unit
  subtotal    Int // quantity * unitPrice (pesos)
}

// A payment made to a supplier against a purchase. Each one creates a
// CashMovement of type EXPENSE. A purchase may have many (partial) payments.
model SupplierPayment {
  id     String   @id @default(cuid())
  date   DateTime @default(now())
  amount Int // pesos, positive
  method String // EFECTIVO | MERCADO_PAGO | TRANSFERENCIA
  notes  String?

  purchaseId String
  purchase   Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([purchaseId])
}

// A discount code the customer types at checkout. Percent OR fixed amount.
model DiscountCode {
  id        String  @id @default(cuid())
  code      String  @unique // stored uppercase, e.g. "BERNA10"
  kind      String // PERCENT | FIXED
  value     Int // percent (0..100) when PERCENT; pesos when FIXED
  active    Boolean @default(true)
  expiresAt DateTime? // optional validity end
  maxUses   Int       @default(0) // 0 = unlimited
  usedCount Int       @default(0)
  minTotal  Int       @default(0) // minimum products subtotal (pesos) to apply

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ---- Costos y Precios (Catálogo) ----

// Global pricing parameters. Singleton: exactly one row (id = "singleton").
model PricingConfig {
  id                       String @id @default("singleton")
  sueldoPercent            Int    @default(15)
  utilidadPercent          Int    @default(50)
  descuentoMayoristaPercent Int   @default(25)
  descuentoKioscoPercent   Int    @default(30)

  updatedAt DateTime @updatedAt
}

// A cost sheet (planilla de costos) for one product+empanado — a flat replica
// of the user's Excel. Only CANTIDAD and PRECIO UNIT fields are stored; every
// total (subtotal, costo1xKg, costo2xKg, sueldo, utilidades, precioFinal) is
// computed in lib/cost-sheets.ts. Many sheets can exist per product+empanado.
model CostSheet {
  id             String   @id @default(cuid())
  productId      String
  product        Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  breadcrumbType String // TRADITIONAL | INTEGRAL | KETO
  fecha          DateTime @default(now())
  notas          String?

  // Materia prima
  compraKg         Float @default(0)
  compraPrecioUnit Int   @default(0) // price per kg
  limpioKg         Float @default(0) // net kg after cleaning (desperdicio = compra − limpio)

  // Otros ítems fijos (todos opcionales)
  huevosCantidad      Int   @default(0)
  huevosPrecioUnit    Int   @default(0)
  integralKg          Float @default(0)
  integralPrecioUnit  Int   @default(0)
  tradicionalKg       Float @default(0)
  tradicionalPrecioUnit Int @default(0)
  marinadaCantidad    Float @default(0)
  marinadaPrecioUnit  Int   @default(0)

  // Producto final
  prodFinalKg       Float @default(0)
  bolsaCantidad     Int   @default(0)
  bolsaPrecioUnit   Int   @default(0)
  etiquetaCantidad  Int   @default(0)
  etiquetaPrecioUnit Int  @default(0)

  // Parámetros (snapshot al guardar)
  sueldoPercent     Int @default(15)
  utilidadesPercent Int @default(50)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId, breadcrumbType])
}

// A competitor's price for a (free-text) product, per kg.
model CompetitorPrice {
  id         String  @id @default(cuid())
  productName String // free text (may match one of our products)
  competitor String
  pricePerKg Int

  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

// Cost change log — one row each time a product+empanado cost changes.
model CostHistory {
  id             String  @id @default(cuid())
  productId      String
  product        Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  breadcrumbType String
  costPerKg      Int
  changedAt      DateTime @default(now())

  @@index([productId, breadcrumbType])
}

// Price change log — one row each time a product+empanado channel price changes.
model PriceHistory {
  id             String  @id @default(cuid())
  productId      String
  product        Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  breadcrumbType String
  channel        String // PUBLICO | MAYORISTA | KIOSCO
  price          Int
  changedAt      DateTime @default(now())

  @@index([productId, breadcrumbType])
}

// A volume discount tier: buying at least `minKg` total grants `discountPercent`
// off the products subtotal. The highest active tier the customer reaches wins.
model QuantityDiscount {
  id              String  @id @default(cuid())
  minKg           Float
  discountPercent Int
  active          Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
